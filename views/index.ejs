<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blogily - Your Personal Blog Platform</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-L724350MBS"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-L724350MBS');
</script>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <h2><i class="fas fa-blog"></i> Blogily</h2>
            </div>
            <div class="nav-menu">
                <a href="/" class="nav-link">Home</a>
                <% if (user) { %>
                    <a href="/create" class="nav-link">Create Blog</a>
                    <span class="nav-user">Welcome, <%= user.username %>!</span>
                    <form action="/logout" method="POST" class="logout-form">
                        <button type="submit" class="logout-btn">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="nav-link">Login</a>
                    <a href="/signup" class="nav-link">Sign Up</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- Search Bar -->
    <div class="search-container">
        <form action="/search" method="GET" class="search-form">
            <div class="search-box">
                <input type="text" name="q" placeholder="Search blogs..." value="<%= searchQuery || '' %>" class="search-input">
                <button type="submit" class="search-btn">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>
    </div>

    <!-- Main Content -->
    <main class="main-content">
        <div class="container">
            <% if (searchQuery) { %>
                <h2 class="search-results">Search Results for "<%= searchQuery %>"</h2>
            <% } else { %>
                <h2 class="page-title">Latest Blog Posts</h2>
            <% } %>

            <% if (blogs.length === 0) { %>
                <div class="no-blogs">
                    <i class="fas fa-newspaper"></i>
                    <h3>No blogs found</h3>
                    <p>Be the first to create a blog post!</p>
                    <% if (user) { %>
                        <a href="/create" class="create-btn">Create Your First Blog</a>
                    <% } else { %>
                        <a href="/signup" class="create-btn">Sign Up to Create Blogs</a>
                    <% } %>
                </div>
            <% } else { %>
                <div class="blogs-grid">
                    <% blogs.forEach(blog => { %>
                        <article class="blog-card">
                            <div class="blog-header">
                                <h3 class="blog-title"><%= blog.title %></h3>
                                <div class="blog-meta">
                                    <span class="author"><i class="fas fa-user"></i> <%= blog.author %></span>
                                    <span class="date"><i class="fas fa-calendar"></i> <%= new Date(blog.createdAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                            <div class="blog-content">
                                <p><%= blog.content.length > 200 ? blog.content.substring(0, 200) + '...' : blog.content %></p>
                            </div>
                            <div class="blog-actions">
                                <div class="reactions">
                                    <form action="/blogs/<%= blog._id %>/like" method="POST" class="inline-form">
                                        <button type="submit" class="btn" title="Like">
                                            <i class="fas fa-thumbs-up"></i> <span><%= (blog.likes && blog.likes.length) || 0 %></span>
                                        </button>
                                    </form>
                                    <form action="/blogs/<%= blog._id %>/dislike" method="POST" class="inline-form">
                                        <button type="submit" class="btn" title="Dislike">
                                            <i class="fas fa-thumbs-down"></i> <span><%= (blog.dislikes && blog.dislikes.length) || 0 %></span>
                                        </button>
                                    </form>
                                </div>
                                <% if (user && user.username === blog.author) { %>
                                    <a href="/edit/<%= blog._id %>" class="btn btn-edit">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <form action="/delete/<%= blog._id %>" method="POST" class="delete-form">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this blog?')">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </form>
                                <% } %>
                            </div>
                        </article>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Blogily. Built with MongoDB and Express.</p>
        </div>
    </footer>
</body>
</html>
