<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Blog - Blogily</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <h2><i class="fas fa-blog"></i> Blogily</h2>
            </div>
            <div class="nav-menu">
                <a href="/" class="nav-link">Home</a>
                <a href="/create" class="nav-link active">Create Blog</a>
                <span class="nav-user">Welcome, <%= user.username %>!</span>
                <form action="/logout" method="POST" class="logout-form">
                    <button type="submit" class="logout-btn">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <!-- Create Blog Form -->
    <main class="create-main">
        <div class="container">
            <div class="create-card">
                <div class="create-header">
                    <h2><i class="fas fa-plus-circle"></i> Create New Blog</h2>
                    <p>Share your thoughts with the world!</p>
                </div>
                
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="error-message">
                        <i class="fas fa-exclamation-circle"></i>
                        <%= error %>
                    </div>
                <% } %>

                <form action="/create" method="POST" class="create-form">
                    <div class="form-group">
                        <label for="title">
                            <i class="fas fa-heading"></i> Blog Title
                        </label>
                        <input type="text" id="title" name="title" placeholder="Enter your blog title..." required>
                    </div>

                    <div class="form-group">
                        <label for="content">
                            <i class="fas fa-edit"></i> Blog Content
                        </label>
                        <textarea id="content" name="content" rows="15" placeholder="Write your blog content here..." required></textarea>
                    </div>

                    <div class="form-actions">
                        <a href="/" class="btn btn-cancel">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-create">
                            <i class="fas fa-save"></i> Create Blog
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
